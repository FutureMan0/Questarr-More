<?xml version="1.0"?>
<Container version="2">
  <Name>Questarr-More</Name>
  <Repository>ghcr.io/futureman0/questarr-more:latest</Repository>
  <Registry>https://ghcr.io</Registry>
  <Network>bridge</Network>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/FutureMan0/Questarr-More/issues</Support>
  <Project>https://github.com/FutureMan0/Questarr-More</Project>
  <Overview>
    **Standard:** Image kommt von **GitHub Container Registry** (`ghcr.io`). Nach einem Push auf `main` baut GitHub Actions automatisch **`latest`** — auf Unraid unter **Docker** beim Container **Questarr-More** auf **Aktualisieren / Update** tippen (oder Container bearbeiten und **Anwenden**), damit das neue Image gezogen wird.
    **Privates GHCR-Paket:** Einmalig auf Unraid `docker login ghcr.io` (siehe `unraid/README.md`).
    **Ohne Registry:** Lokal bauen und Image `questarr-more:local` nutzen — Anleitung in `unraid/README.md` (Variante „lokales Image“).
  </Overview>
  <Category>MediaApp:</Category>
  <WebUI>http://[IP]:[PORT:5000]/</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/FutureMan0/Questarr-More/main/unraid/questarr-more.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/Doezer/Questarr/images/Questarr_icon.png</Icon>
  <ExtraParams>--restart=unless-stopped</ExtraParams>
  <Description>
    Questarr More: Discovery, Bibliothek, Request-Liste, Downloader, optional Auto-Import, RSS/xREL, Light/Dark &amp; Mobile-UI.
    Standard-Image: **ghcr.io/futureman0/questarr-more:latest** (wird bei Push auf `main` gebaut).
  </Description>
  <Networking>
    <Mode>bridge</Mode>
    <Publish>
      <Port>
        <HostPort>5000</HostPort>
        <ContainerPort>5000</ContainerPort>
        <Protocol>tcp</Protocol>
      </Port>
      <Port>
        <HostPort>9898</HostPort>
        <ContainerPort>9898</ContainerPort>
        <Protocol>tcp</Protocol>
      </Port>
    </Publish>
  </Networking>
  <Data>
    <Volume>
      <HostDir>/mnt/user/appdata/questarr-more</HostDir>
      <ContainerDir>/app/data</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
  </Data>
  <Environment>
    <Variable>
      <Value>1000</Value>
      <Name>PUID</Name>
      <Mode/>
    </Variable>
    <Variable>
      <Value>1000</Value>
      <Name>PGID</Name>
      <Mode/>
    </Variable>
    <Variable>
      <Value>/app/data/sqlite.db</Value>
      <Name>SQLITE_DB_PATH</Name>
      <Mode/>
    </Variable>
    <Variable>
      <Value>9898</Value>
      <Name>SSL_PORT</Name>
      <Mode/>
    </Variable>
    <Variable>
      <Value>Europe/Berlin</Value>
      <Name>TZ</Name>
      <Mode/>
    </Variable>
  </Environment>
  <Labels/>
  <Config Name="HTTP Port" Target="5000" Default="5000" Mode="tcp" Description="Web-UI HTTP-Port." Type="Port" Display="always" Required="true" Mask="false">5000</Config>
  <Config Name="HTTPS/SSL Port" Target="9898" Default="9898" Mode="tcp" Description="HTTPS/SSL-Port (muss zu SSL_PORT passen)." Type="Port" Display="always" Required="false" Mask="false">9898</Config>
  <Config Name="Daten-Pfad" Target="/app/data" Default="/mnt/user/appdata/questarr-more" Mode="rw" Description="Persistente Daten inkl. SQLite-Datenbank." Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/questarr-more</Config>
  <Config Name="PUID" Target="PUID" Default="1000" Mode="" Description="User-ID für Dateirechte (z. B. 1000 oder Unraid nobody 99 — siehe Unraid-Doku)." Type="Variable" Display="always" Required="true" Mask="false">1000</Config>
  <Config Name="PGID" Target="PGID" Default="1000" Mode="" Description="Gruppen-ID für Dateirechte." Type="Variable" Display="always" Required="true" Mask="false">1000</Config>
  <Config Name="SQLite DB Pfad" Target="SQLITE_DB_PATH" Default="/app/data/sqlite.db" Mode="" Description="Pfad zur SQLite-Datei **im Container**." Type="Variable" Display="advanced" Required="false" Mask="false">/app/data/sqlite.db</Config>
  <Config Name="SSL Port" Target="SSL_PORT" Default="9898" Mode="" Description="Interner SSL-Port — muss zum gemappten HTTPS-Port passen." Type="Variable" Display="advanced" Required="false" Mask="false">9898</Config>
  <Config Name="Zeitzone" Target="TZ" Default="Europe/Berlin" Mode="" Description="z. B. Europe/Berlin" Type="Variable" Display="advanced" Required="false" Mask="false">Europe/Berlin</Config>
  <Config Name="Games-Pfad (optional)" Target="/games" Default="/mnt/user/games" Mode="rw" Description="Optional: Host-Ordner für die Spiele-Bibliothek." Type="Path" Display="always" Required="false" Mask="false">/mnt/user/games</Config>
</Container>
